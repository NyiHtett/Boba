{
  "manifest_version": 3,
  "name": "Boba",
  "version": "1.0.3",
  "description": "Aesthetic note-taking with Google sign-in cloud sync.",
  "key": "",
  "permissions": [
    "storage",
    "tabs",
    "identity",
    "sidePanel"
  ],
  "oauth2": {
    "client_id": "701906353733-ec5mb5q9shvihoj9qm0sghsqpakusnn0.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Splash",
    "default_popup": "src/popup/index.html"
  },
  "side_panel": {
    "default_path": "src/notes/index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://*.googleapis.com https://*.firebaseio.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com"
  }
}